# Copy this file to .env.local and fill in the keys you have.
# Any model whose key is missing automatically falls back to reference data
# in the dashboard — the app works with zero keys configured.

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
# Also powers the LLM judge (scores quality/reasoning for every model's live
# response) and the "which model should I use?" recommendation engine, so
# it's worth setting even if you don't care about Claude itself.
ANTHROPIC_API_KEY=

# Google AI Studio (Gemini) — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Groq (serves Llama) — https://console.groq.com/keys
GROQ_API_KEY=
